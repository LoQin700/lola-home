    {
      "type": "range",
      "id": "button_size",
      "label": "按钮尺寸",
      "min": 34,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 42
    },
    {
      "type": "color",
      "id": "button_icon_color",
      "label": "按钮图标颜色",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "按钮背景颜色",
      "default": "#F8F8F8"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "按钮边框颜色",
      "default": "#E5E5E5"
    },
    {
      "type": "color",
      "id": "button_hover_icon_color",
      "label": "按钮悬停图标颜色",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "按钮悬停背景颜色",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "按钮悬停边框颜色",
      "default": "#171717"
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "上一张按钮无障碍文本",
      "default": "Previous collections"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "下一张按钮无障碍文本",
      "default": "Next collections"
    },
    {
      "type": "header",
      "content": "宽度与间距"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "内容最大宽度",
      "min": 1000,
      "max": 1900,
      "step": 50,
      "unit": "px",
      "default": 1750
    },
    {
      "type": "range",
      "id": "page_padding",
      "label": "左右留白（电脑端）",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "page_padding_mobile",
      "label": "左右留白（手机端）",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上间距",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下间距",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "产品系列",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "选择产品系列"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "自定义图片（优先显示）"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "自定义系列名称",
          "info": "留空时自动显示产品系列原名"
        }
