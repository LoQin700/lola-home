{% liquid
  assign desktop_columns = section.settings.desktop_columns
  assign mobile_layout = section.settings.mobile_layout
%}

<div
  class="section-background"
  style="background-color: {{ section.settings.background_color }};"
></div>

<section
  id="LolaCollectionCarousel-{{ section.id }}"
  class="section section--{{ section.settings.section_width }} lola-collection-carousel spacing-style"
  data-mobile-layout="{{ mobile_layout }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --lcc-heading-color: {{ section.settings.heading_color }};
    --lcc-title-color: {{ section.settings.collection_title_color }};
    --lcc-card-background: {{ section.settings.card_background }};
    --lcc-gap: {{ section.settings.card_gap }}px;
    --lcc-radius: {{ section.settings.card_radius }}px;
    --lcc-desktop-columns: {{ desktop_columns }};
    --lcc-image-ratio: {{ section.settings.image_ratio }};
    --lola-slider-button-color: {{ section.settings.button_icon_color }};
    --lola-slider-button-bg: {{ section.settings.button_background }};
    --lola-slider-button-border: {{ section.settings.button_border_color }};
    --lola-slider-button-hover-color: {{ section.settings.button_hover_icon_color }};
    --lola-slider-button-hover-bg: {{ section.settings.button_hover_background }};
    --lola-slider-button-hover-border: {{ section.settings.button_hover_border_color }};
  "
>
  <div class="lola-collection-carousel__content">
    <div class="lola-collection-carousel__header">
      {% if section.settings.heading != blank %}
        <h4 class="lola-collection-carousel__heading h4">{{ section.settings.heading }}</h4>
      {% endif %}

      <div
        class="lola-slider-controls lola-collection-carousel__controls{% unless section.settings.show_mobile_arrows %} lola-collection-carousel__controls--desktop-only{% endunless %}"
        data-carousel-controls
        hidden
      >
        <button type="button" class="lola-slider-button" data-carousel-prev aria-label="Previous collections">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M12.75 16.25 6.5 10l6.25-6.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <button type="button" class="lola-slider-button" data-carousel-next aria-label="Next collections">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7.5 3.75 13.75 10 7.5 16.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>

    <lola-collection-slider class="lola-collection-carousel__slider">
      <div
        class="lola-collection-carousel__viewport"
        data-carousel-viewport
        tabindex="0"
        aria-label="{{ section.settings.heading | escape }}"
      >
        <ul class="lola-collection-carousel__track" role="list">
          {% for block in section.blocks %}
            {% liquid
              assign selected_collection = block.settings.collection
              assign card_image = block.settings.custom_image

              if card_image == blank and selected_collection != blank
                assign card_image = selected_collection.image
              endif

              if card_image == blank and selected_collection != blank and selected_collection.products_count > 0
                assign first_product = selected_collection.products.first
                assign card_image = first_product.featured_image
              endif

              assign card_title = block.settings.custom_title | strip
              if card_title == blank and selected_collection != blank
                assign card_title = selected_collection.title
              endif

              if card_title == blank
                assign card_title = 'Collection'
              endif

              assign card_url = '#'
              if selected_collection != blank
                assign card_url = selected_collection.url
              endif

              capture image_sizes
                echo '(min-width: 1200px) calc(100vw / '
                echo desktop_columns
                echo '), (min-width: 990px) 25vw, (min-width: 750px) 33vw, 82vw'
              endcapture
            %}

            <li class="lola-collection-carousel__item" {{ block.shopify_attributes }}>
              <a
                class="lola-collection-carousel__card"
                href="{{ card_url }}"
                {% if selected_collection == blank %}aria-disabled="true"{% endif %}
                aria-label="{{ card_title | escape }}"
              >
                <div class="lola-collection-carousel__media">
                  {% if card_image != blank %}
                    {{
                      card_image
                      | image_url: width: 1200
                      | image_tag:
                        widths: '240, 360, 480, 640, 800, 1000, 1200',
                        sizes: image_sizes,
                        loading: 'lazy',
                        class: 'lola-collection-carousel__image',
                        alt: card_title
                    }}
                  {% else %}
                    {{ 'collection-1' | placeholder_svg_tag: 'lola-collection-carousel__placeholder' }}
                  {% endif %}
                </div>

                <h5 class="lola-collection-carousel__title h5">{{ card_title }}</h5>
              </a>
            </li>
          {% else %}
            {% for i in (1..6) %}
              <li class="lola-collection-carousel__item">
                <div class="lola-collection-carousel__card">
                  <div class="lola-collection-carousel__media">
                    {{ 'collection-' | append: i | placeholder_svg_tag: 'lola-collection-carousel__placeholder' }}
                  </div>
                  <h5 class="lola-collection-carousel__title h5">Collection {{ i }}</h5>
                </div>
              </li>
            {% endfor %}
          {% endfor %}
        </ul>
      </div>
    </lola-collection-slider>
  </div>
</section>

{% stylesheet %}
  .lola-collection-carousel {
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .lola-collection-carousel__content,
  .lola-collection-carousel__slider {
    display: block;
    width: 100%;
    min-width: 0;
  }

  .lola-collection-carousel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 32px;
  }

  .lola-collection-carousel__heading {
    margin: 0;
    color: var(--lcc-heading-color);
  }

  .lola-collection-carousel__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    overscroll-behavior-inline: contain;
    -webkit-overflow-scrolling: touch;
  }

  .lola-collection-carousel__viewport::-webkit-scrollbar {
    display: none;
  }

  .lola-collection-carousel__track {
    display: flex;
    gap: var(--lcc-gap);
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lola-collection-carousel__item {
    flex: 0 0 calc(
      (100% - (var(--lcc-gap) * (var(--lcc-desktop-columns) - 1))) /
        var(--lcc-desktop-columns)
    );
    min-width: 0;
    scroll-snap-align: start;
  }

  .lola-collection-carousel__card {
    display: flex;
    height: 100%;
    min-width: 0;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--lcc-radius);
    background: var(--lcc-card-background);
    color: inherit;
    text-decoration: none;
  }

  .lola-collection-carousel__card[aria-disabled='true'] {
    pointer-events: none;
  }

  .lola-collection-carousel__media {
    position: relative;
    width: 100%;
    aspect-ratio: var(--lcc-image-ratio);
    overflow: hidden;
    background: var(--lcc-card-background);
  }

  .lola-collection-carousel__image,
  .lola-collection-carousel__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  .lola-collection-carousel__image {
    object-fit: cover;
    object-position: center;
    transition: transform 420ms ease;
  }

  .lola-collection-carousel__placeholder {
    fill: rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.03);
  }

  .lola-collection-carousel__card:hover .lola-collection-carousel__image {
    transform: scale(1.035);
  }

  .lola-collection-carousel__title {
    display: grid;
    min-height: 72px;
    place-items: center;
    margin: 0;
    padding: 16px 18px 18px;
    color: var(--lcc-title-color);
    text-align: center;
  }

  .lola-collection-carousel__controls[hidden] {
    display: none;
  }

  @media screen and (max-width: 1199px) and (min-width: 990px) {
    .lola-collection-carousel__item {
      flex-basis: calc((100% - (var(--lcc-gap) * 3)) / 4);
    }
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .lola-collection-carousel__item {
      flex-basis: calc((100% - (var(--lcc-gap) * 2)) / 3);
    }
  }

  @media screen and (max-width: 749px) {
    .lola-collection-carousel__header {
      align-items: flex-start;
      margin-bottom: 22px;
    }

    .lola-collection-carousel__controls--desktop-only {
      display: none;
    }

    .lola-collection-carousel[data-mobile-layout='carousel'] .lola-collection-carousel__item {
      flex-basis: 82%;
    }

    .lola-collection-carousel[data-mobile-layout='grid_2'] {
      overflow: visible;
    }

    .lola-collection-carousel[data-mobile-layout='grid_2'] .lola-collection-carousel__viewport {
      overflow: visible;
      scroll-snap-type: none;
    }

    .lola-collection-carousel[data-mobile-layout='grid_2'] .lola-collection-carousel__track {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
      min-width: 0;
    }

    .lola-collection-carousel[data-mobile-layout='grid_2'] .lola-collection-carousel__item {
      min-width: 0;
    }

    .lola-collection-carousel[data-mobile-layout='grid_2'] .lola-collection-carousel__controls {
      display: none;
    }

    .lola-collection-carousel__title {
      min-height: 58px;
      padding: 12px 10px 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lola-collection-carousel__viewport {
      scroll-behavior: auto;
    }

    .lola-collection-carousel__image {
      transition: none;
    }

    .lola-collection-carousel__card:hover .lola-collection-carousel__image {
      transform: none;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    if (customElements.get('lola-collection-slider')) return;

    class LolaCollectionSlider extends HTMLElement {
      connectedCallback() {
        this.section = this.closest('.lola-collection-carousel');
        this.viewport = this.querySelector('[data-carousel-viewport]');
        this.controls = this.section?.querySelector('[data-carousel-controls]');
        this.previousButton = this.section?.querySelector('[data-carousel-prev]');
        this.nextButton = this.section?.querySelector('[data-carousel-next]');
        this.items = Array.from(this.querySelectorAll('.lola-collection-carousel__item'));

        if (!this.viewport || !this.previousButton || !this.nextButton) return;

        this.onPrevious = () => this.move(-1);
        this.onNext = () => this.move(1);
        this.onScroll = () => this.queueControlUpdate();
        this.onResize = () => this.queueControlUpdate();

        this.previousButton.addEventListener('click', this.onPrevious);
        this.nextButton.addEventListener('click', this.onNext);
        this.viewport.addEventListener('scroll', this.onScroll, { passive: true });
        window.addEventListener('resize', this.onResize);

        if ('ResizeObserver' in window) {
          this.resizeObserver = new ResizeObserver(this.onResize);
          this.resizeObserver.observe(this.viewport);
        }

        requestAnimationFrame(() => this.updateControls());
      }

      disconnectedCallback() {
        this.previousButton?.removeEventListener('click', this.onPrevious);
        this.nextButton?.removeEventListener('click', this.onNext);
        this.viewport?.removeEventListener('scroll', this.onScroll);
        window.removeEventListener('resize', this.onResize);
        this.resizeObserver?.disconnect();
      }

      move(direction) {
        const firstItem = this.items[0];
        if (!firstItem) return;

        const track = this.querySelector('.lola-collection-carousel__track');
        const styles = getComputedStyle(track);
        const gap = Number.parseFloat(styles.columnGap || styles.gap || 0);
        const distance = firstItem.getBoundingClientRect().width + gap;

        this.viewport.scrollBy({
          left: direction * distance,
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth'
        });
      }

      queueControlUpdate() {
        cancelAnimationFrame(this.controlFrame);
        this.controlFrame = requestAnimationFrame(() => this.updateControls());
      }

      updateControls() {
        const mobileGrid =
          window.matchMedia('(max-width: 749px)').matches &&
          this.section?.dataset.mobileLayout === 'grid_2';
        const hasOverflow = !mobileGrid && this.viewport.scrollWidth > this.viewport.clientWidth + 2;

        if (this.controls) this.controls.hidden = !hasOverflow;

        if (!hasOverflow) {
          this.previousButton.disabled = true;
          this.nextButton.disabled = true;
          return;
        }

        const maxScroll = this.viewport.scrollWidth - this.viewport.clientWidth;
        const currentScroll = Math.abs(this.viewport.scrollLeft);

        this.previousButton.disabled = currentScroll <= 2;
        this.nextButton.disabled = currentScroll >= maxScroll - 2;
      }
    }

    customElements.define('lola-collection-slider', LolaCollectionSlider);
  })();
</script>

{% schema %}
{
  "name": "Lola 系列轮播",
  "tag": "section",
  "class": "lola-section-collection-carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "标题设置"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "Explore our collection"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "标题颜色",
      "default": "#171717"
    },
    {
      "type": "header",
      "content": "布局设置"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "每行显示数量",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "移动端布局",
      "options": [
        {
          "value": "carousel",
          "label": "横向轮播"
        },
        {
          "value": "grid_2",
          "label": "两列网格"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "卡片间距",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "图片比例",
      "options": [
        {
          "value": "1 / 1",
          "label": "正方形 1:1"
        },
        {
          "value": "4 / 5",
          "label": "竖向 4:5"
        },
        {
          "value": "4 / 3",
          "label": "横向 4:3"
        }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "卡片圆角",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "颜色设置"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "卡片背景颜色",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "collection_title_color",
      "label": "系列名称颜色",
      "default": "#171717"
    },
    {
      "type": "header",
      "content": "轮播按钮"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_arrows",
      "label": "移动端显示轮播按钮",
      "default": false
    },
    {
      "type": "color",
      "id": "button_icon_color",
      "label": "按钮图标颜色",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "按钮背景颜色",
      "default": "#F8F8F8"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "按钮边框颜色",
      "default": "#D8D8D8"
    },
    {
      "type": "color",
      "id": "button_hover_icon_color",
      "label": "按钮悬停图标颜色",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "按钮悬停背景颜色",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "按钮悬停边框颜色",
      "default": "#171717"
    },
    {
      "type": "header",
      "content": "版面设置"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "内容宽度",
      "options": [
        {
          "value": "page-width",
          "label": "页面宽度"
        },
        {
          "value": "full-width",
          "label": "全宽"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "顶部间距",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "底部间距",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "产品系列",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "产品系列"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "自定义图片"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "显示名称",
          "info": "留空时显示所选产品系列的名称"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lola 系列轮播",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}